# ── Required ─────────────────────────────────────────────────────────────────

# Full backend API URL seen from the browser (leave empty for same-origin fallback in production)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Full public site URL (used to generate absolute sitemap URLs)
NEXT_PUBLIC_SITE_URL=https://cethub.in

# ── Optional: Supabase (if client-side direct API is used) ───────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Optional: Diagnostics & Error Tracking ───────────────────────────────────
# Sentry DSN for frontend client-side error reporting
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Frontend client-side error reporting webhook URL
NEXT_PUBLIC_CLIENT_ERROR_WEBHOOK_URL=
