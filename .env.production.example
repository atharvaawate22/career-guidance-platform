# ── Required ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string (takes precedence over individual DB_* vars below)
DATABASE_URL=postgresql://user:password@host:5432/career_guidance?sslmode=require

# Alternative: individual connection params (used only when DATABASE_URL is unset)
# DB_PASSWORD=change_me
# DB_SSL_REJECT_UNAUTHORIZED=true

# JSON Web Token secret — must be at least 32 characters
JWT_SECRET=change_me_to_a_minimum_32_char_secret
# Token lifetime: accepts "1d", "7d", "2h", "30m", etc.
JWT_EXPIRES_IN=1d

# Admin bootstrap (auto-created/updated on startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_to_a_strong_admin_password

# CORS — comma-separated list of allowed frontend origins
FRONTEND_URL=https://your-frontend-domain.vercel.app

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
# Number of reverse-proxy hops to trust (set to 1 behind Render/Railway/Heroku)
TRUST_PROXY=1

# ── Optional: Email ───────────────────────────────────────────────────────────
# EMAIL_PROVIDER: "smtp" | "gmail" | "mock" (default: "mock")
EMAIL_PROVIDER=mock
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Optional: Google Calendar / Meet link generation ─────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
# Set to "true" to allow mock Meet links outside production (dev/staging only)
ALLOW_MOCK_MEET_LINKS=false

# ── Optional: Seeding ─────────────────────────────────────────────────────────
# Set to "false" to skip sample updates/FAQ seed in production
ENABLE_SAMPLE_SEED=false

# ── Optional: Observability ──────────────────────────────────────────────────
# Backend error webhook (POST { source, level, message, ... })
ERROR_WEBHOOK_URL=
DISABLE_ERROR_WEBHOOK=false

# Slow query threshold in ms (default: 250)
DB_SLOW_QUERY_MS=250

# ── Frontend (NEXT_PUBLIC_* vars) ─────────────────────────────────────────────
# Full backend API URL seen from the browser (leave empty for same-origin)
NEXT_PUBLIC_API_BASE_URL=https://your-backend-api-domain.com
# Optional: client-side error webhook URL
NEXT_PUBLIC_CLIENT_ERROR_WEBHOOK_URL=
