# Server Configuration
PORT=5000

# Database Configuration
# Full connection string (takes precedence over individual PG_* vars)
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_PASSWORD=your_postgres_password_here

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters
JWT_EXPIRES_IN=24h

# Optional hardening controls
# In production, TLS cert validation for DATABASE_URL is always enforced.
# In non-production, set to false only for local/self-signed environments.
DB_SSL_REJECT_UNAUTHORIZED=true

# Controls whether sample updates/FAQ seed data should be inserted at startup.
# Defaults to true in non-production and false in production.
ENABLE_SAMPLE_SEED=false

# Admin User Creation (optional)
# These are used to create an initial admin user on first startup
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_admin_password_here

# CORS — comma-separated list of allowed frontend origins.
# Add each preview deployment URL explicitly.
FRONTEND_URL=http://localhost:3000,https://your-production-domain.com

# Predictor year — update this each academic year without redeploying.
PREDICTOR_YEAR=2025

# Active cutoff year shown in the cutoff explorer UI.
ACTIVE_CUTOFF_YEAR=2025

# Supabase Storage (required for file uploads via admin panel)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Calendar API (optional - for booking functionality)
# If not configured, mock meeting links will be generated
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback
GOOGLE_REFRESH_TOKEN=your_refresh_token
GOOGLE_CALENDAR_ID=primary

# Email Service (optional - for booking confirmations)
# If not configured, mock emails will be logged
EMAIL_PROVIDER=mock

# Optional centralized error tracking webhook
# Example: incident tool or webhook receiver endpoint
ERROR_WEBHOOK_URL=
DISABLE_ERROR_WEBHOOK=false

# SMTP Configuration (if using Gmail or other SMTP provider)
# Uncomment and configure these when EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_gmail_app_password
# SMTP_FROM=your_email@gmail.com

# Proxy trust depth (set to 1 on Render/Railway behind a load balancer)
# TRUST_PROXY=1
